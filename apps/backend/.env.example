# StellChat Backend Configuration

# General
PORT=3000
NODE_ENV=production
RENDER=false

# Persistence (PostgreSQL)
# Use DATABASE_URL for consolidated connection string: 
# postgresql://[user]:[password]@[host]:[port]/[database]
DATABASE_URL=postgresql://postgres:password@localhost:5432/stellchat

# Cache (Redis)
# Use REDIS_URL or REDIS_INTERNAL_URL (preferred on platforms like Render)
REDIS_URL=redis://localhost:6379

# Cloudflare R2 (S3-Compatible Storage)
# Note: Do NOT use the "Cloudflare API Token". 
# You need the "S3 API" credentials found in R2 > Manage R2 API Tokens.
# Create a token with "Edit" permissions for the bucket to get these.
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_BUCKET_NAME=stellchat-media

# Optional: Custom endpoint (e.g., for MinIO or local dev)
# R2_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com

# Public Media URL (The public URL where media can be downloaded)
R2_PUBLIC_ENDPOINT=https://pub-your-id.r2.dev

# Quotas & Limits
INBOX_MAX_MESSAGES=5000
PAIR_PENDING_MAX=50
MEDIA_DAILY_BYTES_LIMIT=104857600
MEDIA_DAILY_COUNT_LIMIT=50
RATE_LIMIT_HOUR=50
RATE_LIMIT_DAY=500

# Firebase Admin SDK (required for FCM push notifications)
# Set to 'true' to enable FCM wakeups; if enabled, credentials must be provided.
# Backend startup will fail if FCM_ENABLED=true and credentials are missing.
FCM_ENABLED=false

# Method A: Individual variables (all three must be present if Method B is not used)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Note: FIREBASE_PRIVATE_KEY must preserve \n characters (e.g. "-----BEGIN PRIVATE KEY-----\nMIIEvg...\n")
FIREBASE_PRIVATE_KEY=

# Method B: Alternative complete service account JSON stringified (e.g. {"type": "service_account", ...})
# Either FCM_SERVICE_ACCOUNT OR the three FIREBASE_* variables above must be present if FCM is enabled.
FCM_SERVICE_ACCOUNT=

