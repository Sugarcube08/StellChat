# StellChat Backend Environment Configuration Example
PORT=3000
NODE_ENV=production
RENDER=false

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/stellchat
REDIS_URL=redis://localhost:6379

# Object Storage
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_BUCKET_NAME=stellchat-media
R2_PUBLIC_ENDPOINT=https://pub-your-id.r2.dev

# Limits
INBOX_MAX_MESSAGES=5000
PAIR_PENDING_MAX=50
MEDIA_DAILY_BYTES_LIMIT=104857600
MEDIA_DAILY_COUNT_LIMIT=50

# Firebase FCM (optional)
FCM_ENABLED=false
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FCM_SERVICE_ACCOUNT=
