# ==========================================
# StellChat Monorepo .gitignore
# ==========================================

# Operating Systems
.DS_Store
Thumbs.db
Desktop.ini
.Spotlight-V100
.Trashes

# IDEs
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
*.iml

# Flutter
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub/
build/
ios/Pods/
ios/.symlinks/
ios/Flutter/Flutter.framework
ios/Flutter/App.framework
android/.gradle/
android/local.properties
# Note: apps/mobile/pubspec.lock is intentionally tracked, do not ignore here

# Android
*.apk
*.aab
*.ap_
captures/
outputs/

# iOS/macOS
DerivedData/
xcuserdata/
*.xcuserstate

# Node.js / TypeScript
node_modules/
npm-debug.log*
yarn-error.log*
pnpm-debug.log*
.turbo/
.next/
dist/
coverage/

# NestJS
.nestjs/

# Rust / Soroban
target/
# Cargo.lock is kept since this is a versioned contract library workspace target

# Docker
*.pid
*.log
docker-data/
docker-volumes/
# Do not ignore Dockerfiles or compose files

# Databases
*.sqlite
*.db
*.db-journal
postgres-data/
redis-data/
minio-data/

# Object Storage
uploads/
buckets/
storage/
media-cache/

# ZK Artifacts
witness.wtns
*.zkey
*.r1cs
*.ptau
*.proof
*.public
*.sym
build/circuits/
generated_proofs/
proving_cache/

# Secrets
.env
.env.*
!.env.example
secrets/
*.pem
*.key
*.p12
*.crt

# Logs
logs/
*.log

# Testing
playwright-report/
test-results/
junit.xml

# Miscellaneous
tmp/
temp/
cache/
.cache/
artifacts/
screenshots/debug/
recordings/
appimagetool
appimagetool*
.antigravitycli
test_snapshots/