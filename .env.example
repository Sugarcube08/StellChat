# StellChat Monorepo Global Environment Example
# Copy this file to .env to configure local dev environment variables.

# Backend config
PORT=3000
NODE_ENV=development

# Database config
DATABASE_URL=postgresql://postgres:password@localhost:5432/stellchat
REDIS_URL=redis://localhost:6379

# Object storage config
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_BUCKET_NAME=stellchat-media
R2_PUBLIC_ENDPOINT=https://pub-your-id.r2.dev

# Prover config
PROVER_PORT=5001

# Stellar network config
STELLAR_NETWORK=standalone
STELLAR_HORIZON_URL=http://localhost:8000
